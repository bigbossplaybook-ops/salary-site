---
// Long-form Boss Playbook pillar page layout. Pages pass metadata and render
// their article body into the slot as plain HTML (h2/h3/p/ul/table).
import Layout from "./Layout.astro";

export interface Props {
  title: string;       // <title> tag, should end with "| Boss Playbook"
  description: string; // meta description, <=155 chars
  h1: string;
  datePublished?: string;
}

const { title, description, h1, datePublished = "2026-07-06" } = Astro.props;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": h1,
  "datePublished": datePublished,
  "dateModified": datePublished,
  "author": { "@type": "Organization", "name": "Boss Playbook" },
  "publisher": { "@type": "Organization", "name": "Boss Playbook" },
};
---

<Layout title={title} description={description} jsonLd={articleJsonLd}>
  <div class="container guide">
    <p class="kicker">Boss Playbook · Executive Compensation</p>
    <h1>{h1}</h1>
    <article class="guide-body">
      <slot />
    </article>

    <section class="cta-block">
      <h2>Get the Full Boss Playbook</h2>
      <p>
        Get the full Boss Playbook compensation strategy — free weekly breakdown
        for GMs and executives.
      </p>
      <a class="cta-btn" href="/newsletter">Get the Weekly Breakdown →</a>
      <p class="cta-social">Follow <strong>@boss.playbook</strong> for daily compensation intel.</p>
    </section>
  </div>
</Layout>

<style is:global>
  .guide { max-width: 760px; padding-top: 2.5rem; }
  .guide .kicker {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .guide h1 {
    font-size: clamp(1.625rem, 4vw, 2.375rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
  }
  .guide-body h2 {
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin: 2.25rem 0 0.875rem;
  }
  .guide-body h3 { font-size: 1.0625rem; font-weight: 700; margin: 1.5rem 0 0.625rem; }
  .guide-body p { margin-bottom: 1rem; line-height: 1.75; font-size: 0.9875rem; }
  .guide-body ul, .guide-body ol { margin: 0 0 1rem 1.375rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .guide-body li { line-height: 1.7; font-size: 0.9875rem; }
  .guide-body table { width: 100%; border-collapse: collapse; font-size: 0.875rem; margin: 1rem 0 1.5rem; }
  .guide-body th {
    text-align: left; padding: 0.5rem 0.75rem; font-size: 0.75rem; text-transform: uppercase;
    letter-spacing: 0.04em; color: var(--color-text-muted); border-bottom: 2px solid var(--color-border);
    background: #f3f4f6;
  }
  .guide-body td { padding: 0.625rem 0.75rem; border-bottom: 1px solid var(--color-border); }
  .guide-body blockquote {
    border-left: 3px solid var(--color-primary);
    padding: 0.5rem 1rem;
    background: #f9fafb;
    border-radius: var(--radius);
    margin: 1rem 0;
    font-style: italic;
  }
  .guide .cta-block {
    background: linear-gradient(135deg, #111827, #1e3a8a);
    color: white;
    border-radius: var(--radius);
    padding: 2rem;
    text-align: center;
    margin: 2.5rem 0;
  }
  .guide .cta-block h2 { font-size: 1.375rem; font-weight: 800; margin-bottom: 0.625rem; }
  .guide .cta-block p { opacity: 0.9; max-width: 520px; margin: 0 auto 1rem; font-size: 0.9375rem; }
  .guide .cta-btn {
    display: inline-block; background: var(--color-accent); color: #111827;
    font-weight: 800; padding: 0.75rem 1.5rem; border-radius: 999px; text-decoration: none;
  }
  .guide .cta-btn:hover { text-decoration: none; filter: brightness(1.05); }
  .guide .cta-social { margin-top: 1rem; font-size: 0.8125rem; opacity: 0.8; }
</style>
