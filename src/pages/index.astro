---
import Layout from "../layouts/Layout.astro";

const jobCategories = [
  { slug: "software-developer", label: "Software Developer", icon: "💻", avgSalary: "$120,000" },
  { slug: "registered-nurse", label: "Registered Nurse", icon: "🏥", avgSalary: "$77,600" },
  { slug: "financial-analyst", label: "Financial Analyst", icon: "📊", avgSalary: "$95,570" },
  { slug: "teacher", label: "Teacher (K-12)", icon: "📚", avgSalary: "$61,820" },
  { slug: "mechanical-engineer", label: "Mechanical Engineer", icon: "⚙️", avgSalary: "$96,310" },
  { slug: "marketing-manager", label: "Marketing Manager", icon: "📣", avgSalary: "$140,040" },
  { slug: "accountant", label: "Accountant", icon: "🧾", avgSalary: "$77,250" },
  { slug: "data-scientist", label: "Data Scientist", icon: "🔬", avgSalary: "$108,020" },
  { slug: "electrician", label: "Electrician", icon: "⚡", avgSalary: "$61,590" },
  { slug: "physical-therapist", label: "Physical Therapist", icon: "🦺", avgSalary: "$97,720" },
  { slug: "sales-manager", label: "Sales Manager", icon: "🤝", avgSalary: "$130,600" },
  { slug: "human-resources-manager", label: "Human Resources Manager", icon: "👥", avgSalary: "$126,230" },
  { slug: "graphic-designer", label: "Graphic Designer", icon: "🎨", avgSalary: "$58,910" },
  { slug: "truck-driver", label: "Truck Driver", icon: "🚚", avgSalary: "$49,920" },
  { slug: "dentist", label: "Dentist", icon: "🦷", avgSalary: "$163,220" },
  { slug: "lawyer", label: "Lawyer", icon: "⚖️", avgSalary: "$148,030" },
  { slug: "pharmacist", label: "Pharmacist", icon: "💊", avgSalary: "$132,750" },
  { slug: "civil-engineer", label: "Civil Engineer", icon: "🏗️", avgSalary: "$92,560" },
  { slug: "real-estate-agent", label: "Real Estate Agent", icon: "🏡", avgSalary: "$56,620" },
  { slug: "cybersecurity-analyst", label: "Cybersecurity Analyst", icon: "🔐", avgSalary: "$112,000" },
];

const topCities = [
  { slug: "new-york-ny", label: "New York, NY" },
  { slug: "los-angeles-ca", label: "Los Angeles, CA" },
  { slug: "chicago-il", label: "Chicago, IL" },
  { slug: "houston-tx", label: "Houston, TX" },
  { slug: "san-francisco-ca", label: "San Francisco, CA" },
];

const currentYear = new Date().getFullYear();
---

<Layout
  title={`US Salary Guide ${currentYear} — Salaries by Job & City`}
  description={`Explore average salaries for hundreds of occupations across 100+ US cities. Find out what you should be earning in ${currentYear} with our free salary guide.`}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">
        <span class="badge">📊 {currentYear} Salary Data</span>
      </div>
      <h1>Find Your True Market Value</h1>
      <p class="hero-sub">
        Real salary data for <strong>hundreds of occupations</strong> across <strong>100+ US cities</strong>.
        Make smarter career decisions with data-backed insights.
      </p>
      <div class="hero-search">
        <p class="search-label">Quick lookup:</p>
        <div class="search-links">
          {topCities.map(city => (
            <a href={`/salary/software-developer/${city.slug}`} class="search-pill">
              Developers in {city.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="categories section" id="categories">
    <div class="container">
      <div class="section-header">
        <h2>Browse by Job Category</h2>
        <p>Select an occupation to explore salaries across US cities</p>
      </div>
      <div class="category-grid">
        {jobCategories.map((cat) => (
          <a href={`/salary/${cat.slug}/new-york-ny`} class="category-card">
            <span class="cat-icon">{cat.icon}</span>
            <div class="cat-info">
              <span class="cat-label">{cat.label}</span>
              <span class="cat-salary">Avg. {cat.avgSalary}/yr</span>
            </div>
            <span class="cat-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="why-us section">
    <div class="container">
      <div class="section-header">
        <h2>Why SalaryInsights?</h2>
      </div>
      <div class="features-grid">
        <div class="feature-card card">
          <span class="feature-icon">📍</span>
          <h3>Location-Specific</h3>
          <p>Salaries vary dramatically by city. Our data breaks it down so you know what's fair in your market.</p>
        </div>
        <div class="feature-card card">
          <span class="feature-icon">📅</span>
          <h3>Always Current</h3>
          <p>Updated regularly with the latest Bureau of Labor Statistics occupational wage data.</p>
        </div>
        <div class="feature-card card">
          <span class="feature-icon">🔍</span>
          <h3>Detailed Breakdowns</h3>
          <p>See entry-level, mid-career, and senior salaries — not just a single average number.</p>
        </div>
        <div class="feature-card card">
          <span class="feature-icon">💡</span>
          <h3>Career Guidance</h3>
          <p>Links to job listings, certifications, and resources to help you earn more.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Lookups -->
  <section class="popular section">
    <div class="container">
      <div class="section-header">
        <h2>Popular Salary Lookups</h2>
      </div>
      <div class="popular-grid">
        {jobCategories.slice(0, 6).map(cat =>
          topCities.slice(0, 3).map(city => (
            <a href={`/salary/${cat.slug}/${city.slug}`} class="popular-link">
              {cat.label} Salary — {city.label}
            </a>
          ))
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 60%, #0ea5e9 100%);
    color: white;
    padding: 5rem 0 4rem;
    text-align: center;
  }

  .hero-badge {
    margin-bottom: 1.25rem;
  }

  .hero .badge {
    background: rgba(255,255,255,0.15);
    color: white;
    border-color: rgba(255,255,255,0.3);
    font-size: 0.875rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: 1.125rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .hero-search {
    margin-top: 2rem;
  }

  .search-label {
    font-size: 0.875rem;
    opacity: 0.75;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .search-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .search-pill {
    background: rgba(255,255,255,0.15);
    color: white;
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.875rem;
    transition: background 0.15s;
    text-decoration: none;
  }

  .search-pill:hover {
    background: rgba(255,255,255,0.28);
    text-decoration: none;
  }

  /* Sections */
  .section {
    padding: 4rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .section-header p {
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  /* Category Grid */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.875rem;
  }

  .category-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
  }

  .category-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .cat-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .cat-info {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .cat-label {
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .cat-salary {
    font-size: 0.8125rem;
    color: var(--color-secondary);
    font-weight: 500;
    margin-top: 0.125rem;
  }

  .cat-arrow {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    flex-shrink: 0;
  }

  /* Features */
  .why-us {
    background: #eff6ff;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .feature-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .feature-icon {
    font-size: 2.25rem;
    display: block;
    margin-bottom: 0.875rem;
  }

  .feature-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Popular */
  .popular-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.625rem;
  }

  .popular-link {
    display: block;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.875rem;
    color: var(--color-primary);
    transition: background 0.15s, border-color 0.15s;
    text-decoration: none;
  }

  .popular-link:hover {
    background: #eff6ff;
    border-color: var(--color-primary);
    text-decoration: none;
  }
</style>
