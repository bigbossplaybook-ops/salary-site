---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="The Boss Playbook Newsletter — Compensation Strategy for Executives"
  description="Free weekly compensation breakdown for GMs, VPs, and senior tech executives. Real numbers, negotiation tactics, and career leverage — no fluff."
>
  <div class="container news">
    <p class="kicker">Boss Playbook</p>
    <h1>The Weekly Compensation Breakdown</h1>
    <p class="lede">
      One email a week for GMs and executives: what roles actually pay, what
      moves the number, and the negotiation tactics that hold up in the room.
      Written by operators, backed by data. Free.
    </p>

    <form
      class="signup"
      name="newsletter-signup"
      method="POST"
      action="mailto:signup@bossplaybook.example?subject=Newsletter%20Signup"
      enctype="text/plain"
    >
      <input type="email" name="email" placeholder="you@company.com" required aria-label="Email address" />
      <button type="submit">Get the Breakdown →</button>
    </form>
    <p class="note">
      Or follow <strong>@boss.playbook</strong> for daily compensation intel.
    </p>

    <div class="proof card">
      <h2>What subscribers get</h2>
      <ul>
        <li>The real 2026 bands for exec roles across 50 US metros — anchored to BLS data, not vibes.</li>
        <li>One negotiation tactic per issue, with the exact language that works at the executive level.</li>
        <li>Equity math explained the way an investor would: 409A, preference stacks, refresh cliffs.</li>
      </ul>
    </div>
  </div>
</Layout>

<style>
  .news { max-width: 640px; text-align: center; padding-top: 3rem; }
  .kicker {
    text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.75rem;
    font-weight: 700; color: var(--color-primary); margin-bottom: 0.5rem;
  }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .lede { color: var(--color-text-muted); font-size: 1.0625rem; line-height: 1.7; margin-bottom: 2rem; }
  .signup { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }
  .signup input {
    flex: 1; min-width: 240px; padding: 0.75rem 1rem; border: 1px solid var(--color-border);
    border-radius: 999px; font-size: 0.9375rem;
  }
  .signup button {
    background: var(--color-primary); color: white; font-weight: 700; border: none;
    padding: 0.75rem 1.5rem; border-radius: 999px; font-size: 0.9375rem; cursor: pointer;
  }
  .signup button:hover { background: var(--color-primary-dark); }
  .note { margin-top: 1rem; font-size: 0.875rem; color: var(--color-text-muted); }
  .proof { margin-top: 2.5rem; text-align: left; }
  .proof h2 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.75rem; }
  .proof ul { margin-left: 1.25rem; display: flex; flex-direction: column; gap: 0.625rem; }
  .proof li { line-height: 1.65; font-size: 0.9375rem; }
</style>
