---
import Layout from "../../../layouts/Layout.astro";
import ExecSalaryPage from "../../../components/ExecSalaryPage.astro";
import citiesData from "../../../../scripts/cities.json";
import { execRoles } from "../../../data/exec-roles.mjs";
import { metros } from "../../../data/metros.mjs";
import { buildFaq, fmt as fmtUsd } from "../../../lib/narrative.mjs";

export async function getStaticPaths() {
  const occupations = [
    { slug: "software-developer", label: "Software Developer",
      wages: { p10: 65000, p25: 85000, median: 120000, p75: 155000, p90: 188000 } },
    { slug: "registered-nurse", label: "Registered Nurse",
      wages: { p10: 52000, p25: 62000, median: 77600, p75: 96000, p90: 118000 } },
    { slug: "financial-analyst", label: "Financial Analyst",
      wages: { p10: 51000, p25: 67000, median: 95570, p75: 131000, p90: 166000 } },
    { slug: "teacher", label: "Teacher (K-12)",
      wages: { p10: 38000, p25: 48000, median: 61820, p75: 77000, p90: 94000 } },
    { slug: "mechanical-engineer", label: "Mechanical Engineer",
      wages: { p10: 61000, p25: 76000, median: 96310, p75: 119000, p90: 144000 } },
    { slug: "marketing-manager", label: "Marketing Manager",
      wages: { p10: 76000, p25: 102000, median: 140040, p75: 185000, p90: 208000 } },
    { slug: "accountant", label: "Accountant",
      wages: { p10: 45000, p25: 57000, median: 77250, p75: 101000, p90: 128000 } },
    { slug: "data-scientist", label: "Data Scientist",
      wages: { p10: 68000, p25: 86000, median: 108020, p75: 136000, p90: 167000 } },
    { slug: "electrician", label: "Electrician",
      wages: { p10: 36000, p25: 46000, median: 61590, p75: 80000, p90: 99000 } },
    { slug: "physical-therapist", label: "Physical Therapist",
      wages: { p10: 69000, p25: 82000, median: 97720, p75: 113000, p90: 129000 } },
    { slug: "sales-manager", label: "Sales Manager",
      wages: { p10: 63000, p25: 92000, median: 130600, p75: 181000, p90: 208000 } },
    { slug: "human-resources-manager", label: "Human Resources Manager",
      wages: { p10: 71000, p25: 95000, median: 126230, p75: 164000, p90: 208000 } },
    { slug: "graphic-designer", label: "Graphic Designer",
      wages: { p10: 33000, p25: 44000, median: 58910, p75: 77000, p90: 99000 } },
    { slug: "truck-driver", label: "Truck Driver",
      wages: { p10: 31000, p25: 39000, median: 49920, p75: 62000, p90: 76000 } },
    { slug: "dentist", label: "Dentist",
      wages: { p10: 82000, p25: 115000, median: 163220, p75: 208000, p90: 208000 } },
    { slug: "lawyer", label: "Lawyer",
      wages: { p10: 61000, p25: 91000, median: 148030, p75: 208000, p90: 208000 } },
    { slug: "pharmacist", label: "Pharmacist",
      wages: { p10: 97000, p25: 118000, median: 132750, p75: 152000, p90: 164000 } },
    { slug: "civil-engineer", label: "Civil Engineer",
      wages: { p10: 57000, p25: 72000, median: 92560, p75: 116000, p90: 143000 } },
    { slug: "real-estate-agent", label: "Real Estate Agent",
      wages: { p10: 26000, p25: 35000, median: 56620, p75: 87000, p90: 120000 } },
    { slug: "cybersecurity-analyst", label: "Cybersecurity Analyst",
      wages: { p10: 65000, p25: 83000, median: 112000, p75: 144000, p90: 174000 } },
  ];

  // Cost-of-living multipliers per city (relative to national average of 1.0)
  const cityMultipliers: Record<string, number> = {};
  citiesData.forEach((city: any) => {
    cityMultipliers[city.slug] = city.costMultiplier ?? 1.0;
  });

  const paths = [];
  const allCities = citiesData as any[];
  for (const occ of occupations) {
    const occIdx = occupations.findIndex((o) => o.slug === occ.slug);
    for (let cityIdx = 0; cityIdx < allCities.length; cityIdx++) {
      const city = allCities[cityIdx];
      const mult = city.costMultiplier ?? 1.0;
      const wages = {
        p10:    Math.round(occ.wages.p10    * mult / 1000) * 1000,
        p25:    Math.round(occ.wages.p25    * mult / 1000) * 1000,
        median: Math.round(occ.wages.median * mult / 1000) * 1000,
        p75:    Math.round(occ.wages.p75    * mult / 1000) * 1000,
        p90:    Math.round(occ.wages.p90    * mult / 1000) * 1000,
      };
      // Deterministic rotating link sets so every page receives inbound links
      // (the old "first 6 cities / fixed 5 occupations" scheme left most pages
      // with zero inbound). Mirrored in src/pages/internal-links.json.ts.
      const relatedOccs = [];
      for (let k = 1; relatedOccs.length < 4; k++) {
        const cand = occupations[(occIdx + cityIdx + k) % occupations.length];
        if (cand.slug !== occ.slug && !relatedOccs.includes(cand)) relatedOccs.push(cand);
      }
      const otherCities = [];
      for (let k = 1; k <= 6; k++) {
        otherCities.push(allCities[(cityIdx + k) % allCities.length]);
      }
      paths.push({
        params: { occupation: occ.slug, location: city.slug },
        props: {
          occupation: occ,
          city,
          wages,
          relatedOccs: relatedOccs.map((o) => ({ slug: o.slug, label: o.label })),
          otherCities: otherCities.map((c) => ({ slug: c.slug, name: c.name, stateAbbr: c.stateAbbr })),
        },
      });
    }
  }

  // Boss Playbook executive pages: 10 exec roles × 50 target metros.
  // Wages anchor to BLS OEWS via exec-roles.mjs and localize with the same
  // costMultiplier model the legacy pages use.
  const cityBySlug = Object.fromEntries(citiesData.map((c: any) => [c.slug, c]));
  for (const role of execRoles) {
    for (const metro of metros) {
      const city = cityBySlug[metro.slug];
      if (!city) throw new Error(`metro ${metro.slug} missing from cities.json`);
      const mult = city.costMultiplier ?? 1.0;
      const wages = {
        p10:    Math.round(role.wages.p10    * mult / 1000) * 1000,
        p25:    Math.round(role.wages.p25    * mult / 1000) * 1000,
        median: Math.round(role.wages.median * mult / 1000) * 1000,
        p75:    Math.round(role.wages.p75    * mult / 1000) * 1000,
        p90:    Math.round(role.wages.p90    * mult / 1000) * 1000,
      };
      paths.push({
        params: { occupation: role.slug, location: metro.slug },
        props: { pageType: "exec", role, metro, city, wages },
      });
    }
  }
  return paths;
}

const { occupation, city, wages, pageType, role, metro, relatedOccs, otherCities } = Astro.props;
const currentYear = new Date().getFullYear();

const fmt = (n: number) =>
  new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }).format(n);

const isExec = pageType === "exec";

let pageTitle: string;
let pageDesc: string;
let pageJsonLd: object[];

if (isExec) {
  pageTitle = `${role.label} Salary in ${city.name} (${currentYear} Guide) | Boss Playbook`;
  pageDesc = `${role.label} salary in ${city.name}: ${fmtUsd(wages.median)} median in ${currentYear}, percentile ranges, top-paying skills, and how to negotiate the offer.`;
  if (pageDesc.length > 155) pageDesc = pageDesc.slice(0, 152).replace(/,?\s+\S*$/, "") + "…";

  const faq = buildFaq({ role, metro, city, wages, year: currentYear });
  pageJsonLd = [
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site?.href ?? "/" },
        { "@type": "ListItem", "position": 2, "name": `${role.label} Salary`, "item": `${Astro.site?.href ?? ""}salary/${role.slug}/` },
        { "@type": "ListItem", "position": 3, "name": city.name, "item": `${Astro.site?.href ?? ""}salary/${role.slug}/${metro.slug}` },
      ],
    },
  ];
} else {
  pageTitle = `${occupation.label} Salary in ${city.name}, ${city.stateAbbr} (${currentYear})`;
  pageDesc = `The average ${occupation.label} salary in ${city.name}, ${city.state} is ${fmt(wages.median)} per year in ${currentYear}. Explore the full salary range from entry-level to senior positions.`;
}

const jsonLd = isExec ? null : {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the average ${occupation.label} salary in ${city.name}, ${city.state}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The average ${occupation.label} salary in ${city.name}, ${city.state} is ${fmt(wages.median)} per year as of ${currentYear}. Entry-level positions start around ${fmt(wages.p10)}, while experienced professionals can earn up to ${fmt(wages.p90)}.`,
      },
    },
    {
      "@type": "Question",
      "name": `What is the highest paid ${occupation.label} salary in ${city.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The top 10% of ${occupation.label}s in ${city.name}, ${city.state} earn ${fmt(wages.p90)} or more per year.`,
      },
    },
  ],
};

const breadcrumbJsonLd = isExec ? null : {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site?.href ?? "/" },
    { "@type": "ListItem", "position": 2, "name": `${occupation.label} Salary`, "item": `${Astro.site?.href ?? ""}salary/${occupation.slug}/` },
    { "@type": "ListItem", "position": 3, "name": city.name, "item": `${Astro.site?.href ?? ""}salary/${occupation.slug}/${city.slug}` },
  ],
};

const affiliateSearchUrl = isExec ? "" : `https://www.indeed.com/jobs?q=${encodeURIComponent(occupation.label)}&l=${encodeURIComponent(city.name + ", " + city.stateAbbr)}`;
const linkedinUrl = isExec ? "" : `https://www.linkedin.com/jobs/search/?keywords=${encodeURIComponent(occupation.label)}&location=${encodeURIComponent(city.name + ", " + city.state)}`;
const glassdoorUrl = isExec ? "" : `https://www.glassdoor.com/Job/jobs.htm?suggestCount=0&suggestChosen=false&clickSource=searchBtn&typedKeyword=${encodeURIComponent(occupation.label)}&sc.keyword=${encodeURIComponent(occupation.label)}&locT=C&locId=&jobType=`;
---

{isExec ? (
  <Layout title={pageTitle} description={pageDesc} jsonLd={pageJsonLd}>
    <ExecSalaryPage role={role} metro={metro} city={city} wages={wages} year={currentYear} />
  </Layout>
) : (
<Layout
  title={pageTitle}
  description={pageDesc}
  jsonLd={[jsonLd, breadcrumbJsonLd]}
>
  <!-- Breadcrumb -->
  <div class="breadcrumb-wrap">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href={`/salary/${occupation.slug}/${city.slug}`}>{occupation.label}</a>
        <span aria-hidden="true">›</span>
        <span>{city.name}, {city.stateAbbr}</span>
      </nav>
    </div>
  </div>

  <div class="container" data-occupation={occupation.slug} data-location={city.slug}>
    <!-- Page Header -->
    <header class="page-header">
      <div class="page-header-inner">
        <h1>{occupation.label} Salary in {city.name}, {city.stateAbbr} ({currentYear})</h1>
        <p class="page-sub">
          Based on Bureau of Labor Statistics occupational wage data adjusted for {city.name} cost of living.
          Last updated <time datetime={`${currentYear}-01-01`}>{currentYear}</time>.
        </p>
      </div>
      <div class="salary-hero-stat">
        <div class="stat-label">Median Annual Salary</div>
        <div class="stat-value" data-salary="median">{fmt(wages.median)}</div>
        <div class="stat-city">{city.name}, {city.state}</div>
      </div>
    </header>

    <div class="page-layout">
      <!-- Main Content -->
      <div class="main-col">

        <!-- Salary Summary Cards -->
        <section class="salary-cards">
          <div class="summary-card low">
            <div class="sc-label">Entry Level (10th pct.)</div>
            <div class="sc-value" data-salary="p10">{fmt(wages.p10)}</div>
            <div class="sc-note">0–2 years experience</div>
          </div>
          <div class="summary-card mid">
            <div class="sc-label">25th Percentile</div>
            <div class="sc-value" data-salary="p25">{fmt(wages.p25)}</div>
            <div class="sc-note">Below average earner</div>
          </div>
          <div class="summary-card median highlight">
            <div class="sc-label">Median (50th pct.)</div>
            <div class="sc-value" data-salary="median">{fmt(wages.median)}</div>
            <div class="sc-note">Typical earner</div>
          </div>
          <div class="summary-card high">
            <div class="sc-label">75th Percentile</div>
            <div class="sc-value" data-salary="p75">{fmt(wages.p75)}</div>
            <div class="sc-note">Above average earner</div>
          </div>
          <div class="summary-card top">
            <div class="sc-label">Top Earner (90th pct.)</div>
            <div class="sc-value" data-salary="p90">{fmt(wages.p90)}</div>
            <div class="sc-note">5+ years experience</div>
          </div>
        </section>

        <!-- Salary Data Table -->
        <section class="data-section card">
          <h2>
            {occupation.label} Salary Breakdown — {city.name}, {city.stateAbbr}
          </h2>
          <p class="section-intro">
            The table below shows how {occupation.label} salaries in {city.name} distribute across experience levels and pay percentiles in {currentYear}.
          </p>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Percentile</th>
                  <th>Annual Salary</th>
                  <th>Monthly</th>
                  <th>Hourly (est.)</th>
                  <th>Profile</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><span class="pct-badge">10th</span></td>
                  <td class="salary-cell">{fmt(wages.p10)}</td>
                  <td>{fmt(Math.round(wages.p10 / 12))}</td>
                  <td>{fmt(Math.round(wages.p10 / 2080))}</td>
                  <td>Entry-level, new graduate</td>
                </tr>
                <tr>
                  <td><span class="pct-badge">25th</span></td>
                  <td class="salary-cell">{fmt(wages.p25)}</td>
                  <td>{fmt(Math.round(wages.p25 / 12))}</td>
                  <td>{fmt(Math.round(wages.p25 / 2080))}</td>
                  <td>1–3 years experience</td>
                </tr>
                <tr class="row-highlight">
                  <td><span class="pct-badge median-badge">Median</span></td>
                  <td class="salary-cell"><strong>{fmt(wages.median)}</strong></td>
                  <td><strong>{fmt(Math.round(wages.median / 12))}</strong></td>
                  <td><strong>{fmt(Math.round(wages.median / 2080))}</strong></td>
                  <td>Mid-career professional</td>
                </tr>
                <tr>
                  <td><span class="pct-badge">75th</span></td>
                  <td class="salary-cell">{fmt(wages.p75)}</td>
                  <td>{fmt(Math.round(wages.p75 / 12))}</td>
                  <td>{fmt(Math.round(wages.p75 / 2080))}</td>
                  <td>Experienced professional</td>
                </tr>
                <tr>
                  <td><span class="pct-badge top-badge">90th</span></td>
                  <td class="salary-cell">{fmt(wages.p90)}</td>
                  <td>{fmt(Math.round(wages.p90 / 12))}</td>
                  <td>{fmt(Math.round(wages.p90 / 2080))}</td>
                  <td>Senior / specialist</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="data-source">
            Source: U.S. Bureau of Labor Statistics Occupational Employment and Wage Statistics (OEWS), adjusted for {city.name} regional cost of living. Data as of {currentYear}.
          </p>
        </section>

        <!-- Salary Bar Chart (CSS-only) -->
        <section class="data-section card">
          <h2>Visual Salary Distribution</h2>
          <div class="bar-chart">
            {[
              { label: "10th pct.", value: wages.p10, max: wages.p90 },
              { label: "25th pct.", value: wages.p25, max: wages.p90 },
              { label: "Median",    value: wages.median, max: wages.p90 },
              { label: "75th pct.", value: wages.p75, max: wages.p90 },
              { label: "90th pct.", value: wages.p90, max: wages.p90 },
            ].map(row => (
              <div class="bar-row">
                <span class="bar-label">{row.label}</span>
                <div class="bar-track">
                  <div
                    class={`bar-fill ${row.label === "Median" ? "bar-median" : ""}`}
                    style={`width: ${Math.round((row.value / row.max) * 100)}%`}
                  />
                </div>
                <span class="bar-val">{fmt(row.value)}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Factors affecting salary -->
        <section class="data-section card">
          <h2>What Affects {occupation.label} Salaries in {city.name}?</h2>
          <ul class="factor-list">
            <li>
              <strong>Experience:</strong> Entry-level professionals earn significantly less than their senior counterparts. In {city.name}, the gap between the 10th and 90th percentile is {fmt(wages.p90 - wages.p10)}.
            </li>
            <li>
              <strong>Industry:</strong> {occupation.label}s working in high-demand industries such as technology, finance, and healthcare often command salaries above the median.
            </li>
            <li>
              <strong>Education & Certifications:</strong> Advanced degrees and relevant professional certifications can move your salary into the upper quartile.
            </li>
            <li>
              <strong>Company size:</strong> Larger organizations typically offer higher compensation packages, including bonuses and equity.
            </li>
            <li>
              <strong>Location within {city.name}:</strong> Employers in downtown/central business districts or tech corridors often pay more than suburban offices.
            </li>
          </ul>
        </section>

        <!-- Find Jobs (Affiliate) -->
        <section class="affiliate-section card" id="find-jobs">
          <h2>🚀 Find {occupation.label} Jobs in {city.name}, {city.stateAbbr}</h2>
          <p>
            Ready to put this salary data to work? Browse open {occupation.label} positions in {city.name} right now on the top job boards.
          </p>
          <div class="affiliate-grid">
            <a href={affiliateSearchUrl} target="_blank" rel="noopener noreferrer" class="affiliate-btn indeed">
              <span class="btn-logo">🔍</span>
              <div class="btn-text">
                <span class="btn-title">Search on Indeed</span>
                <span class="btn-sub">{occupation.label} jobs in {city.name}</span>
              </div>
              <span class="btn-arrow">↗</span>
            </a>
            <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="affiliate-btn linkedin">
              <span class="btn-logo">💼</span>
              <div class="btn-text">
                <span class="btn-title">Search on LinkedIn</span>
                <span class="btn-sub">Connect with {city.name} employers</span>
              </div>
              <span class="btn-arrow">↗</span>
            </a>
            <a href={glassdoorUrl} target="_blank" rel="noopener noreferrer" class="affiliate-btn glassdoor">
              <span class="btn-logo">🚪</span>
              <div class="btn-text">
                <span class="btn-title">Glassdoor Listings</span>
                <span class="btn-sub">Reviews + salary data combined</span>
              </div>
              <span class="btn-arrow">↗</span>
            </a>
          </div>
          <p class="affiliate-note">
            ℹ️ These links may include affiliate tracking. Using them helps support SalaryInsights at no cost to you.
          </p>
        </section>

      </div>

      <!-- Sidebar -->
      <aside class="sidebar-col">
        <div class="sidebar-card card sticky-card">
          <h3>Quick Stats</h3>
          <dl class="quick-stats">
            <dt>Occupation</dt>
            <dd>{occupation.label}</dd>
            <dt>Location</dt>
            <dd>{city.name}, {city.state}</dd>
            <dt>Median Salary</dt>
            <dd class="highlight-stat">{fmt(wages.median)}/yr</dd>
            <dt>Hourly Rate</dt>
            <dd>{fmt(Math.round(wages.median / 2080))}/hr</dd>
            <dt>Monthly Pay</dt>
            <dd>{fmt(Math.round(wages.median / 12))}/mo</dd>
            <dt>Data Year</dt>
            <dd>{currentYear}</dd>
          </dl>
          <a href={affiliateSearchUrl} target="_blank" rel="noopener noreferrer" class="sidebar-cta">
            Find {occupation.label} Jobs →
          </a>
        </div>

        <div class="sidebar-card card">
          <h3>Related Occupations</h3>
          <ul class="related-list">
            {relatedOccs.map((o: any) => (
              <li>
                <a href={`/salary/${o.slug}/${city.slug}`}>
                  {o.label} in {city.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card card">
          <h3>Same Job, Other Cities</h3>
          <ul class="related-list">
            {otherCities.map((c: any) => (
              <li>
                <a href={`/salary/${occupation.slug}/${c.slug}`}>
                  {occupation.label} in {c.name}, {c.stateAbbr}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </div>
  <script src="/js/salary-hydrate.js" defer></script>
</Layout>
)}

<style>
  /* Breadcrumb */
  .breadcrumb-wrap {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 0.625rem 0;
    font-size: 0.8125rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-primary);
  }

  .breadcrumb span:not([aria-hidden]) {
    color: var(--color-text);
    font-weight: 500;
  }

  /* Page Header */
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    margin: 2rem 0;
    flex-wrap: wrap;
  }

  .page-header-inner {
    flex: 1;
    min-width: 280px;
  }

  .page-header h1 {
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 0.625rem;
  }

  .page-sub {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .salary-hero-stat {
    background: linear-gradient(135deg, #1e3a8a, #2563eb);
    color: white;
    border-radius: var(--radius);
    padding: 1.5rem 2rem;
    text-align: center;
    min-width: 200px;
    flex-shrink: 0;
  }

  .stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.8;
